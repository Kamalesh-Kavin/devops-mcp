# Docker socket path — default works for Docker Desktop on macOS
DOCKER_HOST=unix:///var/run/docker.sock

# Shell sandbox settings
# Comma-separated list of executable names that run_command is allowed to use
ALLOWED_COMMANDS=ls,cat,git,df,du,pwd,echo,env,whoami,uname,curl,ps,top,wc,head,tail,find,grep
# Working directory commands are restricted to (leave blank to use cwd)
SANDBOX_DIR=

# Timeout in seconds for run_command
COMMAND_TIMEOUT=10
